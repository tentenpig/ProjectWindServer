<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="Shared\Shared.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="Shared\**" />
    <Content Remove="Shared\**" />
    <EmbeddedResource Remove="Shared\**" />
    <None Remove="Shared\**" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>ProjectWindServer</RootNamespace>
    <AssemblyName>ProjectWindServer</AssemblyName>
  </PropertyGroup>

  <!-- Shared DLL을 Unity 클라이언트 Plugins 폴더로 복사 -->
  <Target Name="CopySharedToClient" AfterTargets="Build">
    <Copy SourceFiles="Shared\bin\$(Configuration)\netstandard2.1\Shared.dll"
          DestinationFolder="$(ProjectDir)..\ProjectWindClient\Assets\Plugins\" />
    <Message Importance="high" Text="[PostBuild] Shared.dll → ProjectWindClient/Assets/Plugins/" />
  </Target>

</Project>
